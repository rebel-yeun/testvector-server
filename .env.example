# =============================================================
# testvector-server environment variables
# Usage: cp .env.example .env  →  edit the values you need
# =============================================================

# NPU test vector root directory (searched recursively for .bin folders)
TESTVECTOR_ROOT=/data/testvector

# Default workload folder (relative path from TESTVECTOR_ROOT)
DEFAULT_WORKLOAD_DIR=cr13/v3.2.0

# Temporary directory for job metadata (cleared on server restart)
# Default: <project_root>/jobs
# JOBS_DIR=/home/user/testvector-server/jobs

# Path to the workload execution script
# Default: <project_root>/run_workloads.sh
# RUN_SCRIPT=/home/user/testvector-server/run_workloads.sh

# Directory for power/thermal data JSON logs
# Default: <project_root>/logs
# LOG_DIR=/home/user/testvector-server/logs

# Server settings
HOST=0.0.0.0
PORT=5000
# DEBUG=false  # keep false in production

# Optional password for running rbln commands with sudo privileges
# Leave unset to try running without sudo
# POWEROFF_SUDO_PASSWORD=your_sudo_password
